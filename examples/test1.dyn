function main() {
	printf("Factorial of 5 is: %d\n", factorial(5));
}

function factorial(n) {
	if (n <= 1) {
		return 1;
	}
	return n * factorial(n - 1);
}

// Prototype inheritance
animal = make_object();
animal.sound = "roar";

dog = make_object();
set_prototype(dog, animal);
printf("Dog sound: %s\n", dog.sound);

// Accidental global
function setX() {
	x = 42;
}
setX();
printf("x = %d\n", x);

// NaN test
printf("NaN == NaN: %d\n", 0/0 == 0/0);

// Precedence test
printf("1 + 2 == 3: %d\n", 1 + 2 == 3);
